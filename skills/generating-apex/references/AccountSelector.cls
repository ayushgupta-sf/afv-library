    public static List<AggregateResult> countByIndustry() {
        return [
            SELECT Industry, COUNT(Id) cnt
            FROM Account
            WHERE Industry != NULL
            GROUP BY Industry
            ORDER BY COUNT(Id) DESC
        ];
